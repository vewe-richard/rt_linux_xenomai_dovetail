-{ }
+{
+	if (leave_inband)
+		fpu__suspend_inband();
+}
 
 static inline
 void arch_dovetail_switch_finish(bool enter_inband)
@@ -24,6 +30,14 @@ void arch_dovetail_switch_finish(bool enter_inband)
 
 	if (unlikely(ti_work & _TIF_IO_BITMAP))
 		tss_update_io_bitmap();
