 		set_thread_esr(addr, esr);
 		arm64_force_sig_fault(inf->sig, inf->code, far, inf->name);
-		oob_trap_unwind(ARM64_TRAP_ACCESS, regs);
+		mark_trap_exit(ARM64_TRAP_ACCESS, regs);
 	} else {
 		__do_kernel_fault(addr, esr, regs);
 	}
@@ -549,7 +549,7 @@ static int __kprobes do_page_fault(unsigned long far, unsigned long esr,
 	if (kprobe_page_fault(regs, esr))
 		return 0;
 
-	oob_trap_notify(ARM64_TRAP_ACCESS, regs);
+	mark_trap_entry(ARM64_TRAP_ACCESS, regs);
 
 	/*
 	 * If we're in an interrupt or have no user context, we must not take
@@ -708,7 +708,7 @@ static int __kprobes do_page_fault(unsigned long far, unsigned long esr,
 no_context:
 	__do_kernel_fault(addr, esr, regs);
 out:
-	oob_trap_unwind(ARM64_TRAP_ACCESS, regs);
+	mark_trap_exit(ARM64_TRAP_ACCESS, regs);
 	return 0;
 }
 
@@ -745,7 +745,7 @@ static int do_sea(unsigned long far, unsigned long esr, struct pt_regs *regs)
 	const struct fault_info *inf;
 	unsigned long siaddr;
 
-	oob_trap_notify(ARM64_TRAP_SEA, regs);
+	mark_trap_entry(ARM64_TRAP_SEA, regs);
 
 	inf = esr_to_fault_info(esr);
 
@@ -770,7 +770,7 @@ static int do_sea(unsigned long far, unsigned long esr, struct pt_regs *regs)
 	add_taint(TAINT_MACHINE_CHECK, LOCKDEP_STILL_OK);
 	arm64_notify_die(inf->name, regs, inf->sig, inf->code, siaddr, esr);
