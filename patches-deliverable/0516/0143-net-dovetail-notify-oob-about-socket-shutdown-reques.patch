From 26bdc5df79e74e607e9166f6453bbfe053c5f110 Mon Sep 17 00:00:00 2001
From: Philippe Gerum <philippe.gerum@exail.com>
Date: Thu, 1 Feb 2024 10:34:34 +0100
Subject: [PATCH 143/175] net: dovetail: notify oob about socket shutdown
 requests

A companion core providing a network stack extension to existing
protocols may want to receive shutdown() requests for sockets. Call
the new sock_oob_shutdown() handler with user-originated requests for
this purpose.

Signed-off-by: Philippe Gerum <philippe.gerum@exail.com>
---
 net/socket.c | 15 ++++++++++++++-
 1 file changed, 14 insertions(+), 1 deletion(-)

diff --git a/net/socket.c b/net/socket.c
index b005fc497e40..3b36ff1912c1 100644
--- a/net/socket.c
+++ b/net/socket.c
@@ -173,6 +173,11 @@ int __weak sock_oob_connect(struct socket *sock,
 	return 0;
 }
 
+int __weak sock_oob_shutdown(struct socket *sock, int how)
+{
+	return 0;
+}
+
 long __weak sock_inband_ioctl_redirect(struct socket *sock,
 				unsigned int cmd, unsigned long arg)
 {
@@ -229,6 +234,11 @@ static inline int sock_oob_connect(struct socket *sock,
 	return 0;
 }
 
+static inline int sock_oob_shutdown(struct socket *sock, int how)
+{
+	return 0;
+}
+
 static inline long sock_inband_ioctl_redirect(struct socket *sock,
 					unsigned int cmd, unsigned long arg)
 {
@@ -2558,8 +2568,11 @@ int __sys_shutdown_sock(struct socket *sock, int how)
 	int err;
 
 	err = security_socket_shutdown(sock, how);
-	if (!err)
+	if (!err) {
 		err = READ_ONCE(sock->ops)->shutdown(sock, how);
+		if (!err && sock_oob_capable(sock))
+			err = sock_oob_shutdown(sock, how);
+	}
 
 	return err;
 }
