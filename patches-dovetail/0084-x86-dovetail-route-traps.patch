 void do_sp_pc_abort(unsigned long addr, unsigned long esr, struct pt_regs *regs)
 {
-	oob_trap_notify(ARM64_TRAP_ALIGN, regs);
+	mark_trap_entry(ARM64_TRAP_ALIGN, regs);
 
