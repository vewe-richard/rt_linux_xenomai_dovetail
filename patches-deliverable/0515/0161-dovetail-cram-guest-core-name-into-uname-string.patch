From aa8ea87d201068f0018f6639272b3841ec3cde0c Mon Sep 17 00:00:00 2001
From: Philippe Gerum <rpm@xenomai.org>
Date: Sun, 27 Oct 2024 16:15:56 +0100
Subject: [PATCH 161/174] dovetail: cram guest core name into uname string

So far uname displayed "IRQ_PIPELINE" unconditionally. Allow for a
companion core to override this information with its own nickname when
present.

A companion core needs to add a shell script named
scripts/dovetail-guest.sh to the source tree which should output its
nickname to stdout. Any error running that script causes the default
"IRQ_PIPELINE" name to be retained.

Signed-off-by: Philippe Gerum <rpm@xenomai.org>
---
 init/Makefile           |  4 ++--
 kernel/Kconfig.dovetail | 11 +++++++++--
 2 files changed, 11 insertions(+), 4 deletions(-)

diff --git a/init/Makefile b/init/Makefile
index 3d25d35ad8cf..516337b8aa0f 100644
--- a/init/Makefile
+++ b/init/Makefile
@@ -27,14 +27,14 @@ smp-flag-$(CONFIG_SMP)			:= SMP
 preempt-flag-$(CONFIG_PREEMPT_BUILD)	:= PREEMPT
 preempt-flag-$(CONFIG_PREEMPT_DYNAMIC)	:= PREEMPT_DYNAMIC
 preempt-flag-$(CONFIG_PREEMPT_RT)	:= PREEMPT_RT
-pipeline-flag-$(CONFIG_IRQ_PIPELINE)	:= IRQ_PIPELINE
+dovetail-flag-$(CONFIG_DOVETAIL)	:= $(CONFIG_DOVETAIL_GUEST)
 
 build-version = $(or $(KBUILD_BUILD_VERSION), $(build-version-auto))
 build-timestamp = $(or $(KBUILD_BUILD_TIMESTAMP), $(build-timestamp-auto))
 
 # Maximum length of UTS_VERSION is 64 chars
 filechk_uts_version = \
-	utsver=$$(echo '$(pound)'"$(build-version)" $(smp-flag-y) $(preempt-flag-y) $(pipeline-flag-y) "$(build-timestamp)" | cut -b -64); \
+	utsver=$$(echo '$(pound)'"$(build-version)" $(smp-flag-y) $(preempt-flag-y) $(dovetail-flag-y) "$(build-timestamp)" | cut -b -64); \
 	echo '$(pound)'define UTS_VERSION \""$${utsver}"\"
 
 #
diff --git a/kernel/Kconfig.dovetail b/kernel/Kconfig.dovetail
index c9ec30d1b4a4..325d3f943ef5 100644
--- a/kernel/Kconfig.dovetail
+++ b/kernel/Kconfig.dovetail
@@ -15,9 +15,16 @@ config DOVETAIL
 	default n
 	help
 	  Activate this option if you want to enable the interface for
-	  running a secondary kernel side-by-side with Linux (aka
-	  "dual kernel" configuration).
+	  running a high-priority software core on the out-of-band
+	  pipeline stage (aka "dual kernel" configuration).
 
 config DOVETAIL_LEGACY_SYSCALL_RANGE
        depends on DOVETAIL
        def_bool y
+
+# The nickname of the guest companion core using Dovetail to attach to
+# the main kernel. Advertise IRQ pipelining only if none.
+config DOVETAIL_GUEST
+       string
+       depends on DOVETAIL
+       default "$(shell,$(srctree)/scripts/dovetail-guest.sh 2>/dev/null || echo IRQ_PIPELINE)"
-- 
2.43.0

