+++ b/arch/arm/include/asm/thread_info.h
@@ -190,6 +190,7 @@ extern int vfp_restore_user_hwstate(struct user_vfp *,
 #define _TLF_OOB		0x0001
 #define _TLF_DOVETAIL		0x0002
