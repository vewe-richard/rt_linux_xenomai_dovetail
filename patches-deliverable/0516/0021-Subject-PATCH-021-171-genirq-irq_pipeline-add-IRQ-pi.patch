 extern void synchronize_irq(unsigned int irq);
@@ -114,6 +115,7 @@ void irq_exit_rcu(void);
 
 #define nmi_enter()						\
 	do {							\
+		irq_pipeline_nmi_enter();			\
 		__nmi_enter();					\
 		lockdep_hardirq_enter();			\
 		ct_nmi_enter();				\
@@ -138,6 +140,22 @@ void irq_exit_rcu(void);
 		ct_nmi_exit();					\
 		lockdep_hardirq_exit();				\
