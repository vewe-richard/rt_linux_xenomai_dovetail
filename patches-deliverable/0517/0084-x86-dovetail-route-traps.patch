@@ -945,7 +946,7 @@ void do_debug_exception(unsigned long addr_if_watchpoint, unsigned long esr,
 	const struct fault_info *inf = esr_to_debug_fault_info(esr);
 	unsigned long pc = instruction_pointer(regs);
 
-	oob_trap_notify(ARM64_TRAP_DEBUG, regs);
+	mark_trap_entry(ARM64_TRAP_DEBUG, regs);
 
 	debug_exception_enter(regs);
 
@@ -958,7 +959,7 @@ void do_debug_exception(unsigned long addr_if_watchpoint, unsigned long esr,
 
 	debug_exception_exit(regs);
 
-	oob_trap_unwind(ARM64_TRAP_DEBUG, regs);
