+		irq_clear_forward(desc);
+		break;
+	default:
+		return true;
 	}
 
 	return false;
 }
 
+static inline bool may_start_flow(int flow)
+{
+	return flow != IRQ_FLOW_REPLAY && flow != IRQ_FLOW_FORWARD;
