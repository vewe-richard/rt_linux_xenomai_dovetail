From 45c1299f36fb3a7914367162ed3e5f2c7a35d51c Mon Sep 17 00:00:00 2001
From: Philippe Gerum <rpm@xenomai.org>
Date: Mon, 4 Nov 2024 14:29:38 +0100
Subject: [PATCH 163/175] net: fec: use netdev_set_oob_capable() helper

Signed-off-by: Philippe Gerum <rpm@xenomai.org>
---
 drivers/net/ethernet/freescale/fec_main.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/net/ethernet/freescale/fec_main.c b/drivers/net/ethernet/freescale/fec_main.c
index f14fb07fc8eb..d8e80d0102cc 100644
--- a/drivers/net/ethernet/freescale/fec_main.c
+++ b/drivers/net/ethernet/freescale/fec_main.c
@@ -4692,7 +4692,7 @@ fec_probe(struct platform_device *pdev)
 	INIT_WORK(&fep->tx_timeout_work, fec_enet_timeout_work);
 
 	if (IS_ENABLED(CONFIG_FEC_OOB)) {
-		ndev->priv_flags |= IFF_OOB_CAPABLE;
+		netdev_set_oob_capable(ndev);
 		netdev_info(ndev, "FEC device is oob-capable\n");
 	}
 
