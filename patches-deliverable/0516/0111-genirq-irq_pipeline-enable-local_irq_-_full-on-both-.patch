From e042b55958db56915cc1dcf6a7e6985cb3eca96e Mon Sep 17 00:00:00 2001
From: Philippe Gerum <philippe.gerum@exail.com>
Date: Sun, 29 Oct 2023 17:00:01 +0100
Subject: [PATCH 111/175] genirq: irq_pipeline: enable local_irq_*_full() on
 both stages

As their names suggest, these calls disable/restore both the hardware
mask and stall bit when running in-band, so as to create a full
interrupt-free section while keeping the stall bit in sync. Extend
these semantics to the oob stage, so that only the hardware state is
affected, since we have no stall bit there.

We already have the test_and_lock_stage() and unlock_stage() calls
available for this purpose, remap local_irq_*_full() to those ones.

Signed-off-by: Philippe Gerum <philippe.gerum@exail.com>
---
 include/linux/irqflags.h | 15 +++++----------
 1 file changed, 5 insertions(+), 10 deletions(-)

diff --git a/include/linux/irqflags.h b/include/linux/irqflags.h
index d3fd19eba9f4..9becb6a9a677 100644
--- a/include/linux/irqflags.h
+++ b/include/linux/irqflags.h
@@ -266,18 +266,13 @@ extern void warn_bogus_irq_restore(void);
 		local_irq_disable();		\
 	} while (0)
 
-#define local_irq_save_full(__flags)		\
-  	do {					\
-		hard_local_irq_disable();	\
-		local_irq_save(__flags);	\
-	} while (0)
-
-#define local_irq_restore_full(__flags)			\
+#define local_irq_save_full(__flags)			\
 	do {						\
-		if (!irqs_disabled_flags(__flags))	\
-			hard_local_irq_enable();	\
-		local_irq_restore(__flags);		\
+		(__flags) = test_and_lock_stage(NULL);	\
 	} while (0)
+
+#define local_irq_restore_full(__flags)	unlock_stage(__flags)
+
 #else
 #define local_irq_enable_full()		local_irq_enable()
 #define local_irq_disable_full()	local_irq_disable()
